---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
import { generateLooseLeafMenu } from '../data/teaHelpers';
import type { MenuCategory, MenuItem } from '../data/teaHelpers';

const baseUrl = import.meta.env.BASE_URL;
const looseLeafMenu = await generateLooseLeafMenu(baseUrl);

const categories: MenuCategory[] = [
  looseLeafMenu,
  {
    id:     'studené',
    title:  'studené nápoje',
    img:    '',
    imgAlt: '',
    items: [
      { name: 'cold brew čaj', desc: 'za studena louhovaný čaj jemné chuti',   price: '80 Kč', },
      // { name: 'domácí limonáda',  desc: 'sirup vařený z ovoce a cukru, konzervovaný kyselinou citrónovou',  price: '78 Kč', },
      // { name: 'matcha s kokosovou vodou', desc: 'ledové letní osvěžení',       price: '108 Kč'                           },
      // { name: 'ledové matcha latte', desc: 's kravským nebo ovesným mlékem',       price: '127 Kč'                           },
      // { name: 'ledové chai latte', desc: 's kravským nebo ovesným mlékem',       price: '127 Kč'                           },
    
    ],
  },
  // {
  //   id:     'specialty',
  //   title:  'čajové speciality',
  //   img:    '',
  //   imgAlt: '',
  //   items: [
  //     { name: 'Masala',         desc: 'zázvor, skořice, kardamom, hřebíček, bílý pepř, černý čaj a mléko', price: '165 Kč',},
  //     { name: 'Matcha affogato',           desc: 'čersvě našlehaná matcha přelitá přes mangovou zmrzlinu',    price: '135 Kč' },
  //      ],
  // },

  {
    id:     'necaje',
    title:  'nečaje',
    img:    '',
    imgAlt: '',
    items: [
      { name: 'kakao',         desc: 'hrnek horkého kakaa', price: '85 Kč', },
      { name: 'rooibos',       desc: 'čajovník kapský, bez kofeinu',   price: '140 Kč'  },
      { name: 'zázvor',         desc: 'čerstvý strouhaný zázvor s citronem a medem',  price: '160 Kč'                   },
      { name: 'máta',      desc: 'nálev ze sušených lístků máty peprné',  price: '150 Kč'                   },
      { name: 'lípa',      desc: 'nálev ze sušených lístků lípy srdčité',  price: '150 Kč'                   },
      { name: 'maliník',      desc: 'nálev ze sušených lístků ostružiníku maliníku',  price: '150 Kč'                   },
      { name: 'kontryhel',      desc: 'nálev ze sušených lístků kontryhelu obecného',  price: '150 Kč'                   },
   
    ],
  },
  {
    id:     'pastry',
    title:  'sladké i slané jídlo',
    img:    '',
    imgAlt: '',
    items: [
      // { name: 'sušené ovoce',        desc: 'jablka / mango / brusinky', price:  '68 Kč'   },
      { name: 'banana bread',      desc: 'vegan, s kousky hořké čokolády',          price: '70 Kč'                     },
      // { name: 'oříšky',          desc: 'mandle',                  price: '70 Kč'                     },
      // { name: 'quesadilla tousty',        desc: 'tortilla placky s fazolemi a sýrem',           price: '95 Kč'                     },
      // { name: 'hummus',        desc: 'cizrna, tahini, oliv. olej, citronová šťáva, česnek, sůl',           price: '95 Kč'                     },
      { name: 'jídlo dne',       desc: 'od oběda do vyprodání',             price: '150 Kč'                     },
    ],
  },
  
];
---

<BaseLayout title="Menu" description="čajovna miska s listím menu — loose-leaf teas, specialty drinks, pastries and tea ceremonies.">
  <Header slot="header" />

  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__eyebrow">naše nabídka</p>
      <h1>lístek nejen čajový</h1>
    </div>
  </section>

  <!-- Category nav -->
  <nav class="cat-nav" aria-label="Menu categories">
    <div class="container cat-nav__list">
      {categories.map(c => (
        <a href={`#${c.id}`} class="cat-nav__link">
          {c.title}
        </a>
      ))}
    </div>
  </nav>

  <!-- Categories -->
  {categories.map((cat, i) => (
    <section id={cat.id} class:list={['menu-section section', { 'section--alt': i % 2 !== 0 }]}>
      <div class="container">
        <div class="menu-section__head">
          <div class="menu-section__text-head">
            <h3>{cat.title}</h3>
            <div class="divider"></div>
          </div>
          {cat.img && (
            <img
              src={cat.img}
              alt={cat.imgAlt}
              class="menu-section__img"
              loading="lazy"
            />
          )}
        </div>

        <div class="menu-items">
          {cat.legend && <p class="menu-legend">{cat.legend}</p>}
          {cat.items.map(item => (
            <div class="menu-item">
              <div class="menu-item__info">
                <h3 class="menu-item__name">
                  {item.name}
                  {item.tag && <span class="menu-item__tag">{item.tag}</span>}
                </h3>
                <p class="menu-item__desc">{item.desc}</p>
              </div>
              <span class="menu-item__price">{item.price}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Allergen note -->
  <section class="allergen section--alt section">
    <div class="container allergen__inner">
      <span class="allergen__icon">ℹ️</span>
      <p>
        Seznam alergenů vám rádi dáme.
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Category nav */
  .cat-nav {
    background:  var(--clr-brown);
    position:    sticky;
    top:         var(--cat-nav-top, 65px);
    z-index:     90;
  }
  .cat-nav__list {
    display:   flex;
    gap:       1.5rem;
    overflow-x: auto;
    padding:   .75rem 0;
    scrollbar-width: none;
  }
  .cat-nav__list::-webkit-scrollbar { display: none; }
  .cat-nav__link {
    white-space:    nowrap;
    color:          var(--clr-parchment);
    font-size:      .85rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    opacity:        .8;
    transition:     opacity .2s;
    padding:        .25rem 0;
    border-bottom:  2px solid transparent;
  }
  .cat-nav__link:hover { opacity: 1; border-color: var(--clr-gold); }

  @media (max-width: 900px) {
    .cat-nav {
      display: none;
    }
  }

  /* Menu section */
  .menu-section__head {
    display:     flex;
    gap:         3rem;
    align-items: flex-start;
    margin-bottom: 2.5rem;
    flex-wrap:   wrap;
  }
  .menu-section__text-head { flex: 1; min-width: 200px; }
  .menu-section__img {
    width:         300px;
    height:        200px;
    object-fit:    cover;
    border-radius: var(--radius-md);
    box-shadow:    var(--shadow);
    flex-shrink:   0;
  }
  @media (max-width: 600px) {
    .menu-section__img { width: 100%; height: 180px; }
  }

  /* Menu items */
  .menu-items { display: flex; flex-direction: column; gap: 0; }
  .menu-legend {
    font-size: .85rem;
    color: var(--clr-text-muted);
    font-style: italic;
    margin-bottom: 1rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--clr-border-medium);
  }
  .menu-item {
    display:       flex;
    justify-content: space-between;
    align-items:   baseline;
    gap:           1rem;
    padding:       1rem 0;
    border-bottom: 1px solid var(--clr-border-soft);
    flex-wrap:     wrap;
  }
  .menu-item:last-child { border-bottom: none; }
  .menu-item__info { flex: 1; }
  .menu-item__name {
    font-family:   var(--ff-display);
    font-size:     1.15rem;
    color:         var(--clr-brown);
    display:       flex;
    align-items:   center;
    gap:           .5rem;
    flex-wrap:     wrap;
    margin-bottom: .2rem;
  }
  .menu-item__tag {
    font-size:     .7rem;
    font-family:   var(--ff-body);
    text-transform: uppercase;
    letter-spacing: .1em;
    background:    var(--clr-caramel);
    color:         var(--clr-cream);
    padding:       .15rem .5rem;
    border-radius: 50px;
  }
  .menu-item__desc { font-size: .9rem; color: var(--clr-text-muted); }
  .menu-item__price {
    font-family:  var(--ff-display);
    font-size:    1.1rem;
    color:        var(--clr-terracotta);
    white-space:  nowrap;
    font-weight:  600;
  }

  /* Allergen */
  .allergen__inner {
    display:     flex;
    gap:         1rem;
    align-items: flex-start;
  }
  .allergen__icon { font-size: 1.3rem; flex-shrink: 0; margin-top: .1rem; }
  .allergen__inner p { font-size: .9rem; color: var(--clr-text-muted); }

  /* Common */
  .page-hero__eyebrow {
    font-family: var(--ff-display);
    font-style:  italic;
    color:       var(--clr-caramel);
    font-size:   1.1rem;
    margin-bottom: .25rem;
  }
</style>
