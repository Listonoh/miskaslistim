---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL;

type RecipeCard = {
  slug: string;
  title: string;
  description: string;
  tag: string;
  image: string | null;
};

const recipeModules = Object.entries(import.meta.glob('./*.md', { eager: true }));

const recipes: RecipeCard[] = recipeModules
  .map(([path, mod]) => {
    const slug = path.replace('./', '').replace(/\.md$/, '');
    const frontmatter = (mod as { frontmatter?: Record<string, unknown> }).frontmatter ?? {};
    const rawImage = typeof frontmatter.coverImage === 'string' ? frontmatter.coverImage : null;
    const image = rawImage ? `${base}${rawImage.replace(/^\/+/, '')}` : null;
    const tag =
      typeof frontmatter.tag === 'string'
        ? frontmatter.tag
        : typeof frontmatter.category === 'string'
          ? frontmatter.category
          : 'Recipe';

    return {
      slug,
      title: typeof frontmatter.title === 'string' ? frontmatter.title : slug,
      description:
        typeof frontmatter.description === 'string'
          ? frontmatter.description
          : 'Recipe notes and serving guidance.',
      tag,
      image,
    };
  })
  .sort((a, b) => a.title.localeCompare(b.title));
---

<BaseLayout title="Recipes" description="Browse recipes from Teahouse miska s listim.">
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <p class="page-hero__eyebrow">Recipe Library</p>
      <h1>All Recipes</h1>
      <p class="page-hero__subtitle">Open a recipe card and read the full preparation notes.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {recipes.length > 0 ? (
        <div class="content-cards-grid">
          {recipes.map((recipe) => (
            <a href={`${base}recipes/${recipe.slug}/`} class="content-card-link">
              <article class="card content-card">
                {recipe.image ? (
                  <img src={recipe.image} alt={recipe.title} class="card__img content-card__img" loading="lazy" />
                ) : (
                  <div class="content-card__img content-card__img--fallback" aria-hidden="true"></div>
                )}
                <div class="card__body">
                  <span class="card__tag">{recipe.tag}</span>
                  <h2 class="card__title content-card__title">{recipe.title}</h2>
                  <p class="card__text">{recipe.description}</p>
                </div>
              </article>
            </a>
          ))}
        </div>
      ) : (
        <article class="card empty-state-card">
          <div class="card__body">
            <span class="card__tag">Recipes</span>
            <h2 class="card__title">No recipes yet</h2>
            <p class="card__text">
              Add a markdown file to src/pages/recipes and it will automatically appear here with its own page.
            </p>
          </div>
        </article>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .content-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.8rem;
  }

  .content-card-link {
    display: block;
  }

  .content-card {
    height: 100%;
  }

  .content-card__img {
    height: 240px;
  }

  .content-card__img--fallback {
    background:
      radial-gradient(circle at 25% 30%, rgba(212, 167, 85, 0.4), transparent 45%),
      linear-gradient(140deg, #f3e8d2 0%, #fdf6ed 55%, #e8d5bd 100%);
  }

  .content-card__title {
    font-size: 1.45rem;
  }

  .empty-state-card {
    max-width: 680px;
    margin: 0 auto;
  }
</style>