---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
import { loadAvailableTeas } from '../data/teaHelpers';

const base = import.meta.env.BASE_URL;
const availableTeas = await loadAvailableTeas(base, 3);
---

<BaseLayout title="Welcome">
  <Header slot="header" />

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero__overlay"></div>
    <img
      src={`${base}uvod-fotka.png`}
      alt="Hands cradling a warm cup of tea"
      class="hero__bg"
      loading="eager"
    />
    <div class="container hero__content">
      <p class="hero__eyebrow">zastavení na cestě</p>
      <h1>chvíle v přítomnosti</h1>
      <p class="hero__sub">
        k dopolední práci na dálku, odpolední kreativitě a večernímu posezení s přáteli
      </p>
      <div class="hero__cta">
        <a href={`${base}menu/`}  class="btn btn--primary">naše menu</a>
        <a href={`${base}about/`} class="btn btn--outline-light">náš příběh</a>
      </div>
    </div>
  </section>

  <!-- ── Feature strip ── -->
  <section class="features section">
    <div class="container">
      <div class="features__grid">
        {[
          { icon: '🍵', title: 'Miska',  text: 'Ochutnejte naše čaje v menším množství.' },
          { icon: '🍵', title: 'Vícenálev',   text: 'Zažijte plný zážitek z našeho čaje, u ktereho můžete sledovat jak se čaj mění v dalších nálevech.'  },
        ].map(f => (
          <div class="feature-card">
            <span class="feature-card__icon">{f.icon}</span>
            <h3>{f.title}</h3>
            <p>{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Koncept ── -->
  <section class="story section section--alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">náš koncept</p>
        <h2>nestálá čajová nabídka</h2>
        <div class="divider divider--center"></div>
        <p>
          Chceme vám nabízet čerstvé a zajímavé čaje. 
          Rozhodli jsme se jít jinou cestou, než jiné čajovny. 
          V naší nabídce najdete výběr 10 čajů různých zpracování i zemí původu. 
        </p>
      </div>
    </div>
  </section>

  <!-- ── Menu highlights ── -->
  <section class="highlights section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">z naší nabídky</p>
        <h2>nové čaje</h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="grid-3">
        {availableTeas.map(tea => (
          <a href={`${base}teas/${tea.slug}/`} class="card card-link">
            {tea.image ? (
              <img src={tea.image} alt={tea.title} class="card__img" loading="lazy" />
            ) : (
              <div class="card__img card__img--fallback" aria-hidden="true"></div>
            )}
            <div class="card__body">
              <h3 class="card__title">{tea.title}</h3>
              <p class="card__text">{tea.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center; margin-top:2.5rem">
        <a href={`${base}menu/`} class="btn btn--outline">View Full Menu</a>
      </div>
    </div>
  </section>

  <!-- ── Latest news teaser ── -->
  <section class="news-teaser section section--alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">latest from the teahouse</p>
        <h2>news &amp; stories</h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="grid-2">
        {[
          {
            img:  'https://images.unsplash.com/photo-1544787219-7f47ccb76574?w=700&q=75',
            date: 'march 2025',
            title:'spring tea ceremony evenings',
            text: 'join us on friday evenings for an intimate guided ceremony celebrating the new harvest',
          },
          {
            img:  'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=700&q=75',
            date: 'february 2025',
            title:'new arrival: yunnan gold tips',
            text: 'a honey-sweet black tea from a family-run garden in yunnan — limited stock available',
          },
        ].map(post => (
          <div class="card news-card">
            <img src={post.img} alt={post.title} class="card__img" loading="lazy" />
            <div class="card__body">
              <span class="card__tag">{post.date}</span>
              <h3 class="card__title">{post.title}</h3>
              <p class="card__text">{post.text}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top:2.5rem">
        <a href={`${base}news/`} class="btn btn--outline">all news</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position:   relative;
    min-height: min(92vh, 780px);
    display:    flex;
    align-items: center;
    overflow:   hidden;
    color:      #fff;
  }
  .hero__bg {
    position:   absolute;
    inset:      0;
    width:      100%;
    height:     100%;
    object-fit: cover;
    object-position: center 60%;
  }
  .hero__overlay {
    position:   absolute;
    inset:      0;
    background: linear-gradient(135deg, rgba(46,31,19,.75) 0%, rgba(92,61,46,.45) 100%);
  }
  .hero__content {
    position:   relative;
    z-index:    1;
    padding:    6rem 0 4rem;
  }
  .hero__eyebrow {
    font-family:    var(--ff-display);
    font-style:     italic;
    font-size:      1.2rem;
    color:          var(--clr-gold);
    margin-bottom:  .5rem;
  }
  .hero h1 { color: #fff; }
  .hero__sub {
    font-size:    1.15rem;
    margin-top:   1rem;
    opacity:      .9;
    line-height:  1.6;
  }
  .hero__cta {
    display:   flex;
    gap:       1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .btn--outline-light {
    background:  transparent;
    color:       #fff;
    border:      2px solid rgba(255,255,255,.7);
    display:     inline-block;
    padding:     .75rem 2rem;
    border-radius: var(--radius-sm);
    font-family: var(--ff-body);
    font-size:   .9rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    transition:  all .25s;
  }
  .btn--outline-light:hover {
    background:  rgba(255,255,255,.15);
    border-color: #fff;
  }

  /* ── Features ── */
  .features__grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap:                   2rem;
    text-align:            center;
  }
  .feature-card { padding: 2rem 1.5rem; }
  .feature-card__icon {
    font-size:     2.5rem;
    display:       block;
    margin-bottom: 1rem;
  }
  .feature-card h3 { margin-bottom: .5rem; }
  .feature-card p  { font-size: .95rem; color: #6b5b4e; margin: 0 auto; }

  /* ── Section heading ── */
  .section-head {
    text-align:    center;
    margin-bottom: 3rem;
  }
  .eyebrow {
    font-family:    var(--ff-display);
    font-style:     italic;
    color:          var(--clr-caramel);
    font-size:      1.05rem;
    margin-bottom:  .25rem;
  }

  /* ── Card link ── */
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform .25s;
  }
  .card-link:hover {
    transform: translateY(-4px);
  }

  /* ── Card fallback image ── */
  .card__img--fallback {
    background:
      radial-gradient(circle at 25% 30%, rgba(212, 167, 85, 0.4), transparent 45%),
      linear-gradient(140deg, #f3e8d2 0%, #fdf6ed 55%, #e8d5bd 100%);
  }
</style>
