---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';
import { loadAvailableTeas } from '../data/teaHelpers';

const base = import.meta.env.BASE_URL;
const availableTeas = await loadAvailableTeas(base, 3);
---

<BaseLayout title="Welcome">
  <Header slot="header" />

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero__overlay"></div>
    <img
      src={`${base}uvod-fotka.jpg`}
      alt="Hands cradling a warm cup of tea"
      class="hero__bg"
      loading="eager"
    />
    <div class="container hero__content">
      <p class="hero__eyebrow">zastavení na cestě</p>
      <h1>chvíle v přítomnosti</h1>
      <p class="hero__sub">
        k dopolední práci na dálku, odpolední kreativitě a večernímu posezení s přáteli
      </p>
      <div class="hero__cta">
        <a href={`${base}menu/`}  class="btn btn--primary">menu</a>
        <a href={`${base}about/`} class="btn btn--outline-light">náš příběh</a>
      </div>
    </div>
  </section>

  <!-- ── Feature strip ── -->
  <section class="features section">
    <div class="container">
      <div class="features__grid">
        {[
          { icon: '🍵', title: 'miska',  text: 'Nejstarší způsob přípravy čaje. Malé množství čajových lístků se v misce koupe v horké, postupně chladnoucí vodě. Některé čaje zvládnou znovuzalití. Při pití si můžete prohlížet lístky.' },
          { icon: '🍵', title: 'vícenálev',   text: 'Malý objem konvičky v poměru k množství čajových lístků dává možnost opakovaného zalévání horkou vodou. Lístky postupně uvolňují svou chuť do nálevů, a tak je každý trochu jiný. Můžete si hrát s přípravou a užít si čaj přesně podle své představy, nebo jen tak experimentovat.'  },
        ].map(f => (
          <div class="feature-card">
            <span class="feature-card__icon">{f.icon}</span>
            <h3>{f.title}</h3>
            <p>{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Koncept ── -->
  <section class="story section section--alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">náš koncept</p>
        <h2>nestálá čajová nabídka</h2>
        <div class="divider divider--center"></div>
        <p>
          10 čajů různých způsobů zpracování i zemí původu. Od každého vždy objednáme omezené množství, a když dojde, došel.
          Na jeho místo v lístku přijde čaj obdobného zpracování. A tak u nás můžete moct ochutnat vždycky něco nového a čerstvého. 
        </p>
      </div>
    </div>
  </section>

  <!-- ── Menu highlights ── -->
  <section class="highlights section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">z naší nabídky</p>
        <h2>nové čaje</h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="grid-3">
        {availableTeas.map(tea => (
          <a href={`${base}teas/${tea.slug}/`} class="card card-link">
            {tea.image ? (
              <img src={tea.image} alt={tea.title} class="card__img" loading="lazy" />
            ) : (
              <div class="card__img card__img--fallback" aria-hidden="true"></div>
            )}
            <div class="card__body">
              <h3 class="card__title">{tea.title}</h3>
              <p class="card__text">{tea.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center; margin-top:2.5rem">
        <a href={`${base}menu/`} class="btn btn--outline">celé menu</a>
      </div>
    </div>
  </section>

  

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position:   relative;
    min-height: min(60vh, 500px);
    display:    flex;
    align-items: center;
    overflow:   hidden;
    color:      var(--clr-cream);
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 140%;
    object-fit: cover;
    object-position: left 40%;
    transform: rotateY(180deg);
  }
  .hero__overlay {
    position:   absolute;
    inset:      0;
    background: linear-gradient(135deg, var(--clr-overlay-dark-strong) 0%, var(--clr-overlay-dark-medium) 100%);
  }
  .hero__content {
    position:   relative;
    z-index:    1;
    padding:    6rem 0 4rem;
  }
  .hero__eyebrow {
    font-family:    var(--ff-display);
    font-style:     italic;
    font-size:      1.2rem;
    color:          var(--clr-cream);
    margin-bottom:  .5rem;
  }
  .hero h1 { color: var(--clr-cream); }
  .hero__sub {
    font-size:    1.15rem;
    margin-top:   1rem;
    opacity:      .9;
    line-height:  1.6;
  }
  .hero__cta {
    display:   flex;
    gap:       1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .btn--outline-light {
    background:  transparent;
    color:       var(--clr-cream);
    border:      2px solid var(--clr-overlay-light-medium);
    display:     inline-block;
    padding:     .75rem 2rem;
    border-radius: var(--radius-sm);
    font-family: var(--ff-body);
    font-size:   .9rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    transition:  all .25s;
  }
  .btn--outline-light:hover {
    background:  var(--clr-overlay-light-subtle);
    border-color: var(--clr-cream);
  }

  /* ── Features ── */
  .features__grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap:                   2rem;
    text-align:            center;
  }
  .feature-card { padding: 2rem 1.5rem; }
  .feature-card__icon {
    font-size:     2.5rem;
    display:       block;
    margin-bottom: 1rem;
  }
  .feature-card h3 { margin-bottom: .5rem; }
  .feature-card p  { font-size: .95rem; color: var(--clr-text-muted); margin: 0 auto; }

  /* ── Section heading ── */
  .section-head {
    text-align:    center;
    margin-bottom: 3rem;
  }
  .eyebrow {
    font-family:    var(--ff-display);
    font-style:     italic;
    color:          var(--clr-caramel);
    font-size:      1.05rem;
    margin-bottom:  .25rem;
  }

  /* ── Card link ── */
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform .25s;
  }
  .card-link:hover {
    transform: translateY(-4px);
  }

  /* ── Card fallback image ── */
  .card__img--fallback {
    background:
      radial-gradient(circle at 25% 30%, var(--clr-accent-soft), var(--clr-transparent) 45%),
      linear-gradient(140deg, var(--clr-parchment) 0%, var(--clr-cream) 55%, var(--clr-caramel) 100%);
  }
</style>
