---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getTeaStockMap, normalizeStatusLabel, resolveTeaStatus, statusClassByLabel } from '../../data/teaStatus';

const base = import.meta.env.BASE_URL;
const stockMap = getTeaStockMap();

const parseAddedDate = (dateStr: unknown): Date | null => {
  if (typeof dateStr !== 'string') return null;
  const [day, month, year] = dateStr.split('.').map(Number);
  if (!day || !month || !year) return null;
  return new Date(year, month - 1, day);
};

type TeaCard = {
  slug: string;
  title: string;
  description: string;
  source: string;
  availability: string;
  availabilityClass: string;
  image: string | null;
  addedDate: Date | null;
};

const teaModules = Object.entries(import.meta.glob('./*.md', { eager: true }));

const teas: TeaCard[] = teaModules
  .map(([path, mod]) => {
    const slug = path.replace('./', '').replace(/\.md$/, '');
    const frontmatter = (mod as { frontmatter?: Record<string, unknown> }).frontmatter ?? {};
    const rawImage = typeof frontmatter.coverImage === 'string' ? frontmatter.coverImage : null;
    const image = rawImage ? `${base}${rawImage.replace(/^\/+/, '')}` : null;
    const availability = normalizeStatusLabel(resolveTeaStatus(stockMap.get(slug)));

    return {
      slug,
      title: typeof frontmatter.title === 'string' ? frontmatter.title : slug,
      description:
        typeof frontmatter.description === 'string'
          ? frontmatter.description
          : 'Tea profile and brewing guide.',
      source: typeof frontmatter.source === 'string' ? frontmatter.source : 'Unknown source',
      availability,
      availabilityClass: statusClassByLabel(availability),
      image,
      addedDate: parseAddedDate(frontmatter.addedDate),
    };
  })
  .sort((a, b) => {
    const timeA = a.addedDate?.getTime() ?? 0;
    const timeB = b.addedDate?.getTime() ?? 0;
    return timeB - timeA;
  });
---

<BaseLayout title="Teas" description="Čaje z čajovny miska s listím.">
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <p class="page-hero__eyebrow">Tea Library</p>
      <h1>All Teas</h1>
      <p class="page-hero__subtitle">Choose a tea and open its full tasting profile.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="tea-cards-grid">
        {teas.map((tea) => (
          <a href={`${base}teas/${tea.slug}/`} class="tea-card-link">
            <article class="card tea-card">
              {tea.image ? (
                <img src={tea.image} alt={tea.title} class="card__img tea-card__img" loading="lazy" />
              ) : (
                <div class="tea-card__img tea-card__img--fallback" aria-hidden="true"></div>
              )}
              <div class="card__body">
                <span class="card__tag">{tea.source}</span>
                {tea.availability && (
                  <span class:list={['tea-card__availability', 'tea-hero__availability', tea.availabilityClass]}>
                    {tea.availability}
                  </span>
                )}
                <h2 class="card__title tea-card__title">{tea.title}</h2>
                <p class="card__text">{tea.description}</p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .tea-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.8rem;
  }

  .tea-card-link {
    display: block;
  }

  .tea-card {
    height: 100%;
  }

  .tea-card__img {
    height: 240px;
  }

  .tea-card__img--fallback {
    background:
      radial-gradient(circle at 25% 30%, rgba(212, 167, 85, 0.4), transparent 45%),
      linear-gradient(140deg, #f3e8d2 0%, #fdf6ed 55%, #e8d5bd 100%);
  }

  .tea-card__title {
    font-size: 1.45rem;
  }

  .tea-card__availability {
    margin-left: .5rem;
    font-size: .7rem;
    letter-spacing: .05em;
    padding: .2rem .6rem;
    vertical-align: middle;
  }
</style>
