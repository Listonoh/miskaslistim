---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const team = [
  {
    name:  'Michaela Clark',
    role:  'čajovnice zvědavá',
    img:   '',
    bio:   'Jsem od podstaty zvědavá bytost, a ta zvědavost mě vede ke zkoumání a propojování směrů, které spolu na první pohled nesouvisí. Hlavně výtvarné umění, pohyb a čaj. Hledám cestu, jak žít. A někde po cestě se objevila myšlenka na tvoření místa…',
  },
  {
    name:  'Jan "Lístek" Urban',
    role:  'Co-Founder',
    img:   '',
    bio:   '',
  },
];

const moto = [
  'Vůně a chutě',
  'Klid a mindfulness',
  'Výdech po práci',
];
---

<BaseLayout title="About Us" description="Proč jsme založili čajovnu miska s listím a co pro nás znamená čaj.">
  <Header slot="header" />

  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__eyebrow">o čajovně</p>
      <h1>miska s listím</h1>
      <p class="page-hero__subtitle">...</p>
    </div>
  </section>

  <!-- Origin story -->
  <section class="section">
    <div class="container story-grid">
      <div class="story-text">
        <div class="divider"></div>
        <p>
          Klidné místo k zastavení na krátkou i dlouhou chvíli, kde čas plyne jinak. Takové útočiště od každodenního shonu. S knihou či kamarádem, nebo sám - čaj je dostatečná společnost.
Sezení na židli je možnost, ale ne jediná. Zvířecí společnost vítaná u stolu s židlemi, na koberci na vlastní dece - s ohledem k ostatním hostům.
        </p>
        <p style="margin-top:1rem">
          ...
        </p>
      </div>
      <div class="story-img">
        <img
          src="https://images.unsplash.com/photo-1556910110-5e0a26b88820?w=700&q=80"
          alt="Rustic teahouse interior with warm lighting and wooden shelves"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Motto -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <h2>můžete u nás hledat</h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="values-grid">
        {moto.map(v => (
          <div class="value-card">
            <p>{v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">koho u nás potkáte</p>
        <div class="divider divider--center"></div>
      </div>
      <div class="team-grid">
        {team.map(member => (
          <div class="team-card">
            <img src={member.img} alt={member.name} class="team-card__photo" loading="lazy" />
            <div class="team-card__body">
              <h3 class="team-card__name">{member.name}</h3>
              <p  class="team-card__role">{member.role}</p>
              <p  class="team-card__bio">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <Footer slot="footer" />
</BaseLayout>

<style>
  .story-grid {
    display:     grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap:         4rem;
    align-items: center;
  }
  .story-img img {
    border-radius: var(--radius-md);
    box-shadow:    var(--shadow);
    width:         100%;
    max-height:    500px;
    object-fit:    cover;
  }
  .story-text p { color: var(--clr-text-muted); }

  /* Motto */
  .values-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap:                   2rem;
  }
  .value-card {
    background:    var(--clr-cream);
    border-radius: var(--radius-md);
    padding:       2rem;
    text-align:    center;
    box-shadow:    var(--shadow);
  }
  .value-card p  { color: var(--clr-text-muted); font-size: .95rem; margin: 0 auto; }

  /* Team */
  .team-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap:                   2rem;
  }
  .team-card {
    background:    var(--clr-cream);
    border-radius: var(--radius-md);
    overflow:      hidden;
    box-shadow:    var(--shadow);
    transition:    transform .25s;
  }
  .team-card:hover { transform: translateY(-4px); }
  .team-card__photo {
    width:      100%;
    height:     260px;
    object-fit: cover;
    object-position: top;
  }
  .team-card__body  { padding: 1.5rem; }
  .team-card__name  { font-size: 1.3rem; margin-bottom: .15rem; }
  .team-card__role  { color: var(--clr-caramel); font-size: .85rem; text-transform: uppercase; letter-spacing: .08em; margin-bottom: .75rem; }
  .team-card__bio   { font-size: .95rem; color: var(--clr-text-muted); }

  /* Section head */
  .section-head { text-align: center; margin-bottom: 3rem; }
  .eyebrow {
    font-family: var(--ff-display);
    font-style:  italic;
    color:       var(--clr-caramel);
    font-size:   1.05rem;
    margin-bottom: .25rem;
  }
  .page-hero__eyebrow {
    font-family: var(--ff-display);
    font-style:  italic;
    color:       var(--clr-caramel);
    font-size:   1.1rem;
    margin-bottom: .25rem;
  }
</style>
