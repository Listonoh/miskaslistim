---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const team = [
  {
    name:  'Misa Clark',
    role:  'Co-Founder & Head Tea Sommelier',
    img:   '',
    bio:   '',
  },
  {
    name:  'Jan "Listek" Urban',
    role:  'Co-Founder',
    img:   '',
    bio:   '',
  },
];

const moto = [
  'Místo, které si užívat všemi smysly.',
  'Klid a mindfulness.',
  'Výdech po práci',
];
---

<BaseLayout title="About Us" description="Pro4 jsme zalo6ili cajovnu Miska s Listim a co pro nas znamena caj.">
  <Header slot="header" />

  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__eyebrow">Our Story</p>
      <h1>About Teahouse miska s listim</h1>
      <p class="page-hero__subtitle">Curiosity, craft &amp; a very good cup of tea.</p>
    </div>
  </section>

  <!-- Origin story -->
  <section class="section">
    <div class="container story-grid">
      <div class="story-text">
        <p class="eyebrow">How it began</p>
        <h2>A love letter<br />to the world's teas</h2>
        <div class="divider"></div>
        <p>
          Misa spent the better part of her twenties as a cultural journalist,
          travelling to remote tea-growing regions across Asia. Every plantation she visited
          — from Darjeeling's mist-wrapped hills to the volcanic soils of Rwanda — left
          an indelible mark on her palate and her perspective.
        </p>
        <p style="margin-top:1rem">
          In 2018, she returned to her hometown of Prague with a simple mission: to share
          what she had learned. Listim ("tea" in playful Czech shorthand) opened its doors
          in a converted courtyard off Náměstí Míru, and the neighbourhood has never been
          the same since.
        </p>
      </div>
      <div class="story-img">
        <img
          src="https://images.unsplash.com/photo-1556910110-5e0a26b88820?w=700&q=80"
          alt="Rustic teahouse interior with warm lighting and wooden shelves"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Motto -->
  <section class="section section--alt">
    <div class="container">
      <div class="section-head">
        <h2>Co očekávat od čajovny</h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="values-grid">
        {moto.map(v => (
          <div class="value-card">
            <p>{v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">The People</p>
        <h2>Meet Our Team</h2>
        <div class="divider divider--center"></div>
      </div>
      <div class="team-grid">
        {team.map(member => (
          <div class="team-card">
            <img src={member.img} alt={member.name} class="team-card__photo" loading="lazy" />
            <div class="team-card__body">
              <h3 class="team-card__name">{member.name}</h3>
              <p  class="team-card__role">{member.role}</p>
              <p  class="team-card__bio">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <Footer slot="footer" />
</BaseLayout>

<style>
  .story-grid {
    display:     grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap:         4rem;
    align-items: center;
  }
  .story-img img {
    border-radius: var(--radius-md);
    box-shadow:    var(--shadow);
    width:         100%;
    max-height:    500px;
    object-fit:    cover;
  }
  .story-text p { color: #5c4a3e; }

  /* Motto */
  .values-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap:                   2rem;
  }
  .value-card {
    background:    var(--clr-cream);
    border-radius: var(--radius-md);
    padding:       2rem;
    text-align:    center;
    box-shadow:    var(--shadow);
  }
  .value-icon {
    font-size:     2.5rem;
    display:       block;
    margin-bottom: 1rem;
  }
  .value-card h3 { margin-bottom: .5rem; }
  .value-card p  { color: #6b5b4e; font-size: .95rem; margin: 0 auto; }

  /* Team */
  .team-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap:                   2rem;
  }
  .team-card {
    background:    var(--clr-cream);
    border-radius: var(--radius-md);
    overflow:      hidden;
    box-shadow:    var(--shadow);
    transition:    transform .25s;
  }
  .team-card:hover { transform: translateY(-4px); }
  .team-card__photo {
    width:      100%;
    height:     260px;
    object-fit: cover;
    object-position: top;
  }
  .team-card__body  { padding: 1.5rem; }
  .team-card__name  { font-size: 1.3rem; margin-bottom: .15rem; }
  .team-card__role  { color: var(--clr-caramel); font-size: .85rem; text-transform: uppercase; letter-spacing: .08em; margin-bottom: .75rem; }
  .team-card__bio   { font-size: .95rem; color: #6b5b4e; }

  /* Visit CTA */
  .visit-cta__inner {
    display:     grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap:         4rem;
    align-items: start;
  }
  .visit-info { display: flex; flex-direction: column; gap: 1.5rem; }
  .info-block h4 {
    font-family:  var(--ff-display);
    color:        var(--clr-terracotta);
    font-size:    1rem;
    margin-bottom: .25rem;
  }
  .info-block p  { font-size: .95rem; color: #5c4a3e; }
  .info-block a  { color: var(--clr-terracotta); }

  /* Section head */
  .section-head { text-align: center; margin-bottom: 3rem; }
  .eyebrow {
    font-family: var(--ff-display);
    font-style:  italic;
    color:       var(--clr-caramel);
    font-size:   1.05rem;
    margin-bottom: .25rem;
  }
  .page-hero__eyebrow {
    font-family: var(--ff-display);
    font-style:  italic;
    color:       var(--clr-caramel);
    font-size:   1.1rem;
    margin-bottom: .25rem;
  }
</style>
