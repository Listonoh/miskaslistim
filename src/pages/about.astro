---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const team = [
  {
    name:  'Michaela Clark',
    role:  'čajovnice zvědavá',
    img:   `${base}misa_profil.jpg`,
    bio:   'Jsem od podstaty zvědavá bytost, a ta zvědavost mě vede ke zkoumání a propojování směrů, které spolu na první pohled nesouvisí. Hlavně výtvarné umění, pohyb a čaj. Hledám cestu, jak žít. A někde po cestě se objevila myšlenka na tvoření místa…',
  },
  {
    name:  'Jan "Lístek" Urban',
    role:  'čajovník obecný',
    img:   `${base}listek_profil.jpg`,
    bio:   'Když jedna cesta nevyjde, tak se vydám další. \
    Tak trochu skáču z jednoho odvětví do jiného a baví mě zkoušet nové věci. \
    Zároveň na cestě mě vždy provázel čaj a chuť vytvářet klidný prostor pro další lidi. \
    Tak po vyhoření jako programátor jdu zkusit něco kde se používají ruce a komunikuje se víc s lidmi.',
  },
];

const heroGallery = [
  {
    src: `${base}zvenku.jpg`,
    alt: 'Pohled na cely exterier cajovny',
  },
  {
    src: `${base}mistnost-2.jpg`,
    alt: 'Interier cajovny s usporadanim stolu',
  },
  {
    src: `${base}mistnost-1-1.jpg`,
    alt: 'Klidna cast interieru s detailnim pohledem',
  },
  {
    src: `${base}mistnost-1-2.jpg`,
    alt: 'Druhy pohled na interier cajovny',
  },
];

---

<BaseLayout title="About Us" description="Proč jsme založili čajovnu miska s listím a co pro nás znamená čaj.">
  <Header slot="header" />

  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__eyebrow">o čajovně</p>
      <h1>miska s listím</h1>
      <p class="page-hero__subtitle">...</p>
    </div>
  </section>

  <section class="about-gallery" aria-label="Fotky z cajovny">
    <div class="about-gallery__track">
      {heroGallery.map(photo => (
        <figure class="about-gallery__item">
          <img src={photo.src} alt={photo.alt} loading="lazy" />
        </figure>
      ))}
    </div>
  </section>

  <!-- Origin story -->
  <section class="section">
    <div class="container story-grid">
      <div class="story-text">
        <div class="divider"></div>
        
        <h3>Co je to čajovna?</h3>
        <p>
Místo, kde si můžu vychutnat kvalitní čaj. Ale spíš než o čaj jde o atmosféru. Klid a zpomalení v dnešní době tolik potřebné. Mindfullness je slovo často zmiňované, ale jak to může vypadat v praxi? Miska čaje v ruce příjemně hřeje, vůně mě vybízí k ochutnání…Prostě všímavost všemi smysly! A v prostředí, kde je hudba jemná, v pozadí, si k čaji můžu vzít knihu, přijít posedět s přáteli, potkat nové podobně laděné lidi…
</p>
<br>
<br>
<h3>K dobrému čaji patří i dobré jídlo!</h3>
<p>
Vaříme jedno veganské jídlo za den - obědovou misku, která zasytí. Ve stálé nabídce najdete i hummus a banánový chlebík. Vše vlastní výroby. Jídelní i nápojový lístek se bude do budoucna ještě rozšiřovat. Pro ty z vás, kdo nemůžou nebo nechtějí čaj, také něco máme. Bylinky, rooibos nebo třeba kakao.
</p>
<br>
<br>
<h3>Čaj v létě?</h3>
<p>
Za nás rozhodně ano, ale pokud preferujete studené pití, taky si u nás vyberete. Ledové, za studena louhované čaje (maceráty), domácí ovocnou limonádu, ovesné matcha latté, nebo naši specialitu - matchu s kokosovou vodou.
        </p>
      </div>
     
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">koho u nás potkáte</p>
        <div class="divider divider--center"></div>
      </div>
      <div class="team-grid">
        {team.map(member => (
          <div class="team-card">
            <img src={member.img} alt={member.name} class="team-card__photo" loading="lazy" />
            <div class="team-card__body">
              <h3 class="team-card__name">{member.name}</h3>
              <p  class="team-card__role">{member.role}</p>
              <p  class="team-card__bio">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <Footer slot="footer" />
</BaseLayout>

<style>
  .story-grid {
    display:     grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap:         4rem;
    align-items: center;
  }
  .story-img img {
    border-radius: var(--radius-md);
    box-shadow:    var(--shadow);
    width:         100%;
    max-height:    500px;
    object-fit:    cover;
  }
  .story-text p { color: var(--clr-text-muted); }

  /* Team */
  .team-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap:                   2rem;
  }
  .team-card {
    background:    var(--clr-cream);
    border-radius: var(--radius-md);
    overflow:      hidden;
    box-shadow:    var(--shadow);
    transition:    transform .25s;
  }
  .team-card:hover { transform: translateY(-4px); }
  .team-card__photo {
    width:      100%;
    height:     600px;
    object-fit: cover;
    object-position: center;
  }
  .team-card__body  { padding: 1.5rem; }
  .team-card__name  { font-size: 1.3rem; margin-bottom: .15rem; }
  .team-card__role  { color: var(--clr-caramel); font-size: .85rem; text-transform: uppercase; letter-spacing: .08em; margin-bottom: .75rem; }
  .team-card__bio   { font-size: .95rem; color: var(--clr-text-muted); }

  /* Section head */
  .section-head { text-align: center; margin-bottom: 3rem; }
  .eyebrow {
    font-family: var(--ff-display);
    font-style:  italic;
    color:       var(--clr-caramel);
    font-size:   1.05rem;
    margin-bottom: .25rem;
  }
  .page-hero__eyebrow {
    font-family: var(--ff-display);
    font-style:  italic;
    color:       var(--clr-caramel);
    font-size:   1.1rem;
    margin-bottom: .25rem;
  }

  .about-gallery {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
  }

  .about-gallery__track {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: .35rem;
  }

  .about-gallery__item {
    margin: 0;
  }

  .about-gallery__item img {
    width: 100%;
    height: clamp(120px, 20vw, 300px);
    object-fit: cover;
  }
</style>
