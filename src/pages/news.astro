---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header     from '../components/Header.astro';
import Footer     from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

interface NewsPost {
  slug:     string;
  title:    string;
  date:     string;
  category: string;
  excerpt:  string;
  img:      string;
  imgAlt:   string;
  featured: boolean;
}

const posts: NewsPost[] = [
  
];

const featured = posts.filter(p => p.featured);
const rest     = posts.filter(p => !p.featured);

const categories = [...new Set(posts.map(p => p.category))];
---

<BaseLayout title="News" description="Stories, events, and updates from Teahouse miska s listim teahouse in Prague.">
  <Header slot="header" />

  <!-- Page hero -->
  <section class="page-hero">
    <div class="container">
      <p class="page-hero__eyebrow">From the Teahouse</p>
      <h1>News &amp; Stories</h1>
      <p class="page-hero__subtitle">What's steeping at Listim.</p>
    </div>
  </section>

  <!-- Featured posts -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Featured</p>
      <h2>Latest Highlights</h2>
      <div class="divider"></div>

      <div class="featured-grid">
        {featured.map((post, i) => (
          <article class:list={['featured-card', { 'featured-card--large': i === 0 }]}>
            <img src={post.img} alt={post.imgAlt} class="featured-card__img" loading={i === 0 ? 'eager' : 'lazy'} />
            <div class="featured-card__body">
              <span class="featured-card__cat">{post.category}</span>
              <h3 class="featured-card__title">{post.title}</h3>
              <time class="featured-card__date" datetime={post.date}>{post.date}</time>
              <p class="featured-card__excerpt">{post.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- All posts -->
  <section class="section section--alt">
    <div class="container">
      <!-- Category filter (visual only — all posts shown) -->
      <div class="filter-bar">
        <span class="filter-label">Browse by:</span>
        {['All', ...categories].map(cat => (
          <button class:list={['filter-btn', { active: cat === 'All' }]} type="button">
            {cat}
          </button>
        ))}
      </div>

      <div class="posts-grid">
        {rest.map(post => (
          <article class="card news-card">
            <img src={post.img} alt={post.imgAlt} class="card__img" loading="lazy" />
            <div class="card__body">
              <span class="card__tag">{post.category}</span>
              <h3 class="card__title">{post.title}</h3>
              <time class="news-date" datetime={post.date}>{post.date}</time>
              <p class="card__text">{post.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter section">
    <div class="container newsletter__inner">
      <div>
        <p class="eyebrow">Stay in the Loop</p>
        <h2>Join Our Newsletter</h2>
        <div class="divider"></div>
        <p>One gentle email per month — new teas, upcoming events and a small story from the teahouse.</p>
      </div>
      <form class="newsletter__form" onsubmit="return false;">
        <label for="email" class="sr-only">Email address</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="your@email.com"
          required
          class="newsletter__input"
          autocomplete="email"
        />
        <button type="submit" class="btn btn--primary">Subscribe</button>
      </form>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Featured grid */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap:     2rem;
    margin-top: 2rem;
  }

  .featured-card {
    border-radius: var(--radius-md);
    overflow:      hidden;
    box-shadow:    var(--shadow);
    background:    var(--clr-cream);
    display:       flex;
    flex-direction: column;
    transition:    transform .25s;
  }
  .featured-card:hover { transform: translateY(-4px); }

  .featured-card--large {
    grid-column: 1 / -1;
    flex-direction: row;
  }
  .featured-card--large .featured-card__img {
    width:      50%;
    height:     360px;
    flex-shrink: 0;
  }
  @media (max-width: 700px) {
    .featured-card--large { flex-direction: column; }
    .featured-card--large .featured-card__img { width: 100%; height: 220px; }
  }

  .featured-card__img {
    width:      100%;
    height:     220px;
    object-fit: cover;
  }
  .featured-card__body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: .4rem;
  }
  .featured-card__cat {
    font-size:      .75rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color:          var(--clr-caramel);
  }
  .featured-card__title { font-size: clamp(1.2rem, 2.5vw, 1.7rem); }
  .featured-card__date {
    font-size: .8rem;
    color:     #9e8576;
  }
  .featured-card__excerpt { font-size: .95rem; color: #6b5b4e; margin-top: .25rem; }

  /* Filter bar */
  .filter-bar {
    display:   flex;
    gap:       .75rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 2rem;
  }
  .filter-label { font-size: .85rem; color: #9e8576; }
  .filter-btn {
    background:     transparent;
    border:         1px solid var(--clr-caramel);
    color:          var(--clr-brown);
    padding:        .35rem 1rem;
    border-radius:  50px;
    font-size:      .8rem;
    cursor:         pointer;
    transition:     all .2s;
  }
  .filter-btn.active,
  .filter-btn:hover {
    background: var(--clr-caramel);
    color:      #fff;
    border-color: var(--clr-caramel);
  }

  /* Posts grid */
  .posts-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap:                   2rem;
  }
  .news-date {
    display:    block;
    font-size:  .78rem;
    color:      #9e8576;
    margin-top: .25rem;
  }

  /* Newsletter */
  .newsletter__inner {
    display:     grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap:         3rem;
    align-items: center;
  }
  .newsletter__form {
    display:   flex;
    gap:       .75rem;
    flex-wrap: wrap;
  }
  .newsletter__input {
    flex:          1;
    min-width:     200px;
    padding:       .75rem 1rem;
    border:        2px solid var(--clr-parchment);
    border-radius: var(--radius-sm);
    background:    var(--clr-parchment);
    font-family:   var(--ff-body);
    font-size:     1rem;
    color:         var(--clr-dark);
    transition:    border-color .2s;
  }
  .newsletter__input:focus {
    outline:      none;
    border-color: var(--clr-caramel);
  }

  /* Common */
  .eyebrow {
    font-family:   var(--ff-display);
    font-style:    italic;
    color:         var(--clr-caramel);
    font-size:     1.05rem;
    margin-bottom: .25rem;
  }
  .page-hero__eyebrow {
    font-family: var(--ff-display);
    font-style:  italic;
    color:       var(--clr-caramel);
    font-size:   1.1rem;
    margin-bottom: .25rem;
  }
  .sr-only {
    position:   absolute;
    width:      1px;
    height:     1px;
    overflow:   hidden;
    clip:       rect(0,0,0,0);
    white-space: nowrap;
  }
</style>
