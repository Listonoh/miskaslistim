---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;
const title = frontmatter?.title ?? 'Post Detail';
const description = frontmatter?.description ?? 'Article details and story.';
const eyebrow = frontmatter?.eyebrow ?? 'Post Detail';
const subtitle = frontmatter?.subtitle ?? 'Read the full story.';
const metaLabel = frontmatter?.metaLabel ?? 'Source';
const metaValue = frontmatter?.metaValue ?? frontmatter?.source ?? null;
const coverImage = frontmatter?.coverImage
  ? `${base}${String(frontmatter.coverImage).replace(/^\/+/, '')}`
  : null;
const coverAlt = frontmatter?.coverAlt ?? title;
const galleryImages = Array.isArray(frontmatter?.galleryImages)
  ? frontmatter.galleryImages.map((img: string) => `${base}${String(img).replace(/^\/+/, '')}`)
  : [];
const galleryAltBase = frontmatter?.galleryAltBase ?? title;
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <section class="page-hero post-hero">
    <div class="container">
      <p class="page-hero__eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="page-hero__subtitle">{subtitle}</p>
      {metaValue && <p class="post-hero__meta">{metaLabel}: {metaValue}</p>}
    </div>
  </section>

  <section class="section">
    <div class="container post__container">
      {coverImage && (
        <figure class="post-cover">
          <img src={coverImage} alt={coverAlt} loading="eager" />
        </figure>
      )}

      <article class="prose-post">
        <slot />
      </article>

      {galleryImages.length > 0 && (
        <section class="post-gallery" aria-label="Post gallery">
          <h2>Gallery</h2>
          <div class="post-gallery__grid">
            {galleryImages.map((img, index) => (
              <figure class="post-gallery__item">
                <img src={img} alt={`${galleryAltBase} detail ${index + 1}`} loading="lazy" />
              </figure>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>