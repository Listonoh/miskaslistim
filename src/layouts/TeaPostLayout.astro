---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getTeaStockMap, normalizeStatusLabel, resolveTeaStatus, statusClassByLabel } from '../data/teaStatus';

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;
const title = frontmatter?.title ?? 'Tea Detail';
const description = frontmatter?.description ?? 'Tea tasting notes and brewing guide.';
const source = frontmatter?.source ?? 'Unknown source';
const teaSlug = Astro.url.pathname.split('/').filter(Boolean).at(-1) ?? '';
const stockMap = getTeaStockMap();
const stockItem = stockMap.get(teaSlug);
const fallbackAvailability = typeof frontmatter?.availability === 'string' ? frontmatter.availability : '';
const resolvedStatus = resolveTeaStatus(stockItem);
const availabilityLabel = normalizeStatusLabel(resolvedStatus || fallbackAvailability);
const availabilityClass = statusClassByLabel(availabilityLabel);
const coverImage = frontmatter?.coverImage
  ? `${base}${String(frontmatter.coverImage).replace(/^\/+/, '')}`
  : null;
const galleryImages = Array.isArray(frontmatter?.galleryImages)
  ? frontmatter.galleryImages.map((img: string) => `${base}${String(img).replace(/^\/+/, '')}`)
  : [];
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <section class="page-hero tea-hero">
    <div class="container">
      <h1>{title}</h1>
      <p class="tea-hero__source">Od: {source}</p>
      {availabilityLabel && (
        <p class={`tea-hero__availability ${availabilityClass}`}>Dostupnost: {availabilityLabel}</p>
      )}
    </div>
  </section>

  <section class="tea-post section">
    <div class="container tea-post__container">
      {coverImage && (
        <figure class="tea-cover">
          <img src={coverImage} alt={`${title} tea leaves`} loading="eager" />
        </figure>
      )}

      <article class="prose-tea">
        <slot />
      </article>

      {galleryImages.length > 0 && (
        <section class="tea-gallery" aria-label="Tea gallery">
          <div class="tea-gallery__grid">
            {galleryImages.map((img, i) => (
              <figure class="tea-gallery__item">
                <img src={img} alt={`${title} detail ${i + 1}`} loading="lazy" />
              </figure>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
