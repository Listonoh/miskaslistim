---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="logo__leaf">🍃</span>
      <span class="footer-name">Miska's <em>Listim</em></span>
      <p class="footer-tagline">A serene teahouse where every cup tells a story.</p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <h4>Quick Links</h4>
      <ul>
        <li><a href={base}>Home</a></li>
        <li><a href={`${base}about/`}>About Us</a></li>
        <li><a href={`${base}teas/`}>Teas</a></li>
        <li><a href={`${base}menu/`}>Menu</a></li>
        <li><a href={`${base}news/`}>News</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <h4>Find Us</h4>
      <address>
        <p>12 Leaf Lane, Tea Quarter</p>
        <p>Praha 1, 110 00</p>
        <p><a href="mailto:hello@miskaslistim.cz">hello@miskaslistim.cz</a></p>
        <p><a href="tel:+420123456789">+420 123 456 789</a></p>
      </address>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {year} Miska's Listim. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background:  var(--clr-brown);
    color:       var(--clr-parchment);
    padding-top: 4rem;
  }

  .footer-inner {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap:                   3rem;
    padding-bottom:        3rem;
  }

  .footer-name {
    font-family: var(--ff-display);
    font-size:   1.5rem;
    font-weight: 600;
    color:       #fff;
  }
  .footer-name em { color: var(--clr-gold); font-style: italic; }
  .footer-tagline {
    margin-top: .5rem;
    font-size:  .9rem;
    opacity:    .75;
    max-width:  28ch;
  }

  .footer-nav h4,
  .footer-contact h4 {
    font-family:    var(--ff-display);
    font-size:      1.1rem;
    color:          var(--clr-gold);
    margin-bottom:  1rem;
  }

  .footer-nav ul { list-style: none; }
  .footer-nav li { margin-bottom: .5rem; }
  .footer-nav a,
  .footer-contact a {
    color:      var(--clr-parchment);
    opacity:    .85;
    transition: opacity .2s;
  }
  .footer-nav a:hover,
  .footer-contact a:hover { opacity: 1; }

  address { font-style: normal; line-height: 1.9; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,.12);
    padding:    1rem 0;
    font-size:  .82rem;
    opacity:    .6;
    text-align: center;
  }
</style>
