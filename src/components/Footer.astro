---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <nav class="footer-nav" aria-label="Footer navigation">
      <ul>
        <li><a href={base}>DOMŮ</a></li>
        <li><a href={`${base}about/`}>O ČAJOVNĚ</a></li>
        <li><a href={`${base}teas/`}>ČAJE</a></li>
        <!-- <li><a href={`${base}recipes/`}>RECEPTY</a></li> -->
        <li><a href={`${base}menu/`}>MENU</a></li>
        <!-- <li><a href={`${base}news/`}>NOVINKY</a></li> -->
        <li><a href={`${base}way/`}>KDE</a></li>
      </ul>
    </nav>

    <div class="footer-contact">
      <h4>KDE NÁS NAJDETE</h4>
      <address>
        <p>Poděbradská 242/10</p>
        <p>Praha 9, 190 00</p>
        <p><a href="mailto:info@miskaslistim.cz">info@miskaslistim.cz</a></p>
        <p><a href="tel:+420123456789">+420 123 456 789</a></p>
        <p>IČO: 08268908</p>
      </address>
    </div>
    <div class="footer-contact opening-hours">
      <h4>OTEVÍRACÍ DOBA</h4>
      <p class="hours-row"><span class="day">pondělí</span><span class="time closed">ZAVŘENO</span></p>
      <p class="hours-row"><span class="day">úterý</span><span class="time">10:00-21:00</span></p>
      <p class="hours-row"><span class="day">středa</span><span class="time">10:00-21:00</span></p>
      <p class="hours-row"><span class="day">čtvrtek</span><span class="time">10:00-21:00</span></p>
      <p class="hours-row"><span class="day">pátek</span><span class="time">10:00-21:00</span></p>
      <p class="hours-row"><span class="day">sobota</span><span class="time">10:00-21:00</span></p>
      <p class="hours-row"><span class="day">neděle</span><span class="time closed">ZAVŘENO</span></p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>© {year} čajovna miska s listím. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background:  var(--clr-brown);
    color:       var(--clr-parchment);
    padding-top: 4rem;
  }

  .footer-inner {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap:                   3rem;
    padding-bottom:        3rem;
  }

  .footer-contact h4 {
    font-family:    var(--ff-display);
    font-size:      1.1rem;
    color:          var(--clr-gold);
    margin-bottom:  1rem;
  }

  .footer-nav ul { list-style: none; }
  .footer-nav li { margin-bottom: .5rem; }
  .footer-nav a,
  .footer-contact a {
    color:      var(--clr-parchment);
    opacity:    .85;
    transition: opacity .2s;
  }
  .footer-nav a:hover,
  .footer-contact a:hover { opacity: 1; }

  address { font-style: normal; line-height: 1.9; }

  .opening-hours .hours-row {
    display:               grid;
    grid-template-columns: minmax(7.5ch, auto) auto;
    column-gap:            1rem;
    align-items:           baseline;
    max-width:             280px;
  }

  .opening-hours .time {
    white-space: nowrap;
  }

  .opening-hours .closed {
    font-weight:    700;
    letter-spacing: .04em;
  }

  .footer-bottom {
    border-top: 1px solid var(--clr-border-on-dark);
    padding:    1rem 0;
    font-size:  .82rem;
    opacity:    .6;
    text-align: center;
  }
</style>
